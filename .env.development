# Loaded ONLY by `next dev` (never by `next build`), so this is dev-only and does
# not affect the compose-prod build (build.args) or the prod-kube image (no args
# → browser-origin resolution). It restores the pre-existing standalone `pnpm dev`
# behaviour: resolve the backend at `localhost/` (nginx :80) instead of the dev
# server's own origin (:3000). The docker-compose dev stack overrides these via
# .env.dev with identical values.
NEXT_PUBLIC_BACKEND_HOST=localhost/
NEXT_PUBLIC_BACKEND_PROTOCOL=http://
NEXT_PUBLIC_WEBSOCKET_PROTOCOL=ws://
