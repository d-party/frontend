{
  "openapi": "3.0.3",
  "info": {
    "title": "d-party backend API",
    "version": "1.0.0",
    "description": "Public REST surface of the d-party backend consumed by the user-facing frontend. Mirrors the schema used by the Chrome extension and adds the lobby room-resolution endpoint used by the room-transition page. The full schema can later be generated by drf-spectacular (`manage.py spectacular`)."
  },
  "servers": [
    {
      "url": "/"
    }
  ],
  "paths": {
    "/api/v1/chrome-extension/version-check": {
      "get": {
        "operationId": "versionCheck",
        "summary": "Check whether an extension version is compatible with the backend.",
        "parameters": [
          {
            "name": "extension-version",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Extension version in strict x.y.z form."
          }
        ],
        "responses": {
          "200": {
            "description": "Compatibility result.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VersionCheckResult"
                }
              }
            }
          },
          "400": {
            "description": "Missing extension-version parameter.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiMessage"
                }
              }
            }
          },
          "406": {
            "description": "Malformed version string.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiMessage"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/anime-store/lobby/{room_id}": {
      "get": {
        "operationId": "lobbyResolve",
        "summary": "Resolve a room id to the dアニメストア player URL the lobby should redirect to.",
        "description": "Server-side replacement for the old Django `AnimeRoomLobby` view: looks up the AnimeRoom and returns the fully-built dアニメストア redirect URL (including partId / party=join / room_id query params).",
        "parameters": [
          {
            "name": "room_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "description": "Room UUID embedded in the shared lobby link."
          }
        ],
        "responses": {
          "200": {
            "description": "Resolved redirect target.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LobbyRedirect"
                }
              }
            }
          },
          "404": {
            "description": "Room not found or already closed (deleted).",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiMessage"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/statistics/anime-store/anime-user-all-count": {
      "get": {
        "operationId": "statsUserAllCount",
        "summary": "Total user count.",
        "responses": {
          "200": {
            "description": "Count.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CountResult"
                }
              }
            }
          }
        },
        "parameters": [
          {
            "name": "days",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 365,
              "default": 365
            },
            "description": "Aggregation window length in days (1-365, default 365)."
          }
        ]
      }
    },
    "/api/v1/statistics/anime-store/anime-room-all-count": {
      "get": {
        "operationId": "statsRoomAllCount",
        "summary": "Total room count.",
        "responses": {
          "200": {
            "description": "Count.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CountResult"
                }
              }
            }
          }
        },
        "parameters": [
          {
            "name": "days",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 365,
              "default": 365
            },
            "description": "Aggregation window length in days (1-365, default 365)."
          }
        ]
      }
    },
    "/api/v1/statistics/anime-store/anime-reaction-all-count": {
      "get": {
        "operationId": "statsReactionAllCount",
        "summary": "Total reaction count.",
        "responses": {
          "200": {
            "description": "Count.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CountResult"
                }
              }
            }
          }
        },
        "parameters": [
          {
            "name": "days",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 365,
              "default": 365
            },
            "description": "Aggregation window length in days (1-365, default 365)."
          }
        ]
      }
    },
    "/api/v1/statistics/anime-store/anime-user-alive-count": {
      "get": {
        "operationId": "statsUserAliveCount",
        "summary": "Currently connected user count.",
        "responses": {
          "200": {
            "description": "Count.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CountResult"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/statistics/anime-store/anime-room-alive-count": {
      "get": {
        "operationId": "statsRoomAliveCount",
        "summary": "Currently active room count.",
        "responses": {
          "200": {
            "description": "Count.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CountResult"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/statistics/anime-store/active-user-per-day": {
      "get": {
        "operationId": "statsActiveUserPerDay",
        "summary": "Daily count of users.",
        "responses": {
          "200": {
            "description": "Per-day counts.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PerDayResult"
                }
              }
            }
          }
        },
        "parameters": [
          {
            "name": "days",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 365,
              "default": 365
            },
            "description": "Aggregation window length in days (1-365, default 365)."
          }
        ]
      }
    },
    "/api/v1/statistics/anime-store/active-room-per-day": {
      "get": {
        "operationId": "statsActiveRoomPerDay",
        "summary": "Daily count of rooms.",
        "responses": {
          "200": {
            "description": "Per-day counts.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PerDayResult"
                }
              }
            }
          }
        },
        "parameters": [
          {
            "name": "days",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 365,
              "default": 365
            },
            "description": "Aggregation window length in days (1-365, default 365)."
          }
        ]
      }
    },
    "/api/v1/statistics/anime-store/anime-reaction-count": {
      "get": {
        "operationId": "statsReactionCount",
        "summary": "Per-type reaction counts.",
        "responses": {
          "200": {
            "description": "Per-type counts.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReactionTypeCountResult"
                }
              }
            }
          }
        },
        "parameters": [
          {
            "name": "days",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 365,
              "default": 365
            },
            "description": "Aggregation window length in days (1-365, default 365)."
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "VersionCheckResult": {
        "type": "object",
        "required": [
          "is_possible"
        ],
        "properties": {
          "is_possible": {
            "type": "boolean",
            "description": "True if the extension version is supported."
          }
        }
      },
      "LobbyRedirect": {
        "type": "object",
        "required": [
          "redirect_url",
          "part_id",
          "room_id"
        ],
        "properties": {
          "redirect_url": {
            "type": "string",
            "format": "uri",
            "description": "Fully-built dアニメストア URL to redirect the user to."
          },
          "part_id": {
            "type": "string",
            "description": "Episode (part) id associated with the room."
          },
          "room_id": {
            "type": "string",
            "format": "uuid",
            "description": "Echoed room UUID."
          },
          "title": {
            "type": "string",
            "description": "Anime title captured by the extension at room creation. May be empty for rooms created by older extension versions."
          }
        }
      },
      "ApiMessage": {
        "type": "object",
        "required": [
          "message"
        ],
        "properties": {
          "message": {
            "type": "string"
          }
        }
      },
      "CountResult": {
        "type": "object",
        "required": [
          "data"
        ],
        "properties": {
          "data": {
            "type": "object",
            "required": [
              "count"
            ],
            "properties": {
              "count": {
                "type": "integer"
              }
            }
          }
        }
      },
      "PerDayResult": {
        "type": "object",
        "required": [
          "data"
        ],
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "day",
                "count"
              ],
              "properties": {
                "day": {
                  "type": "string",
                  "format": "date"
                },
                "count": {
                  "type": "integer"
                }
              }
            }
          }
        }
      },
      "ReactionTypeCountResult": {
        "type": "object",
        "required": [
          "data"
        ],
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "count",
                "reaction_type"
              ],
              "properties": {
                "count": {
                  "type": "integer"
                },
                "reaction_type": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    }
  }
}
